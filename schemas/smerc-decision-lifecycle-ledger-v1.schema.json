{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smerc.example/schemas/smerc-decision-lifecycle-ledger-v1.schema.json",
  "title": "SMERC Decision Lifecycle Ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "decision_id", "tenant_id", "record_count", "head_record_hash", "records", "summary", "verification"],
  "properties": {
    "version": {"const": "smerc.decision-lifecycle-ledger.v1"},
    "decision_id": {"type": "string", "minLength": 1, "maxLength": 192},
    "tenant_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "record_count": {"type": "integer", "minimum": 0},
    "head_record_hash": {"$ref": "#/$defs/hash"},
    "records": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"}
    },
    "summary": {"type": "object"},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "record_count", "head_record_hash", "errors"],
      "properties": {
        "valid": {"type": "boolean"},
        "record_count": {"type": "integer", "minimum": 0},
        "head_record_hash": {"$ref": "#/$defs/hash"},
        "errors": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_version", "sequence", "decision_id", "tenant_id", "event_type", "actor", "recorded_at", "previous_record_hash", "payload", "record_hash"],
      "properties": {
        "record_version": {"const": "smerc.dll-record.v1"},
        "sequence": {"type": "integer", "minimum": 1},
        "decision_id": {"type": "string", "minLength": 1, "maxLength": 192},
        "tenant_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "event_type": {"enum": ["REQUEST", "EVIDENCE", "EVALUATION", "HUMAN_INTERACTION", "EXECUTION", "OUTCOME", "LEARNING_RECOMMENDATION"]},
        "actor": {"type": "string", "minLength": 1, "maxLength": 128},
        "recorded_at": {"type": "string", "format": "date-time"},
        "previous_record_hash": {"$ref": "#/$defs/hash"},
        "payload": {"type": "object"},
        "record_hash": {"$ref": "#/$defs/hash"}
      }
    }
  }
}

