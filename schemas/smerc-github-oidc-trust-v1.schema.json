{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smerc.example/schemas/smerc-github-oidc-trust-v1.schema.json",
  "title": "SMERC GitHub Actions OIDC Trust Policy v1",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "tenant_id", "repository", "repository_id", "repository_owner_id",
      "subjects", "refs", "workflow_refs", "workflow_shas", "events", "environments", "scopes"
    ],
    "properties": {
      "tenant_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
      "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
      "repository_id": {"type": "string", "pattern": "^[0-9]+$"},
      "repository_owner_id": {"type": "string", "pattern": "^[0-9]+$"},
      "subjects": {"$ref": "#/$defs/non_empty_unique_strings"},
      "refs": {"$ref": "#/$defs/non_empty_unique_strings"},
      "workflow_refs": {"$ref": "#/$defs/non_empty_unique_strings"},
      "workflow_shas": {
        "type": "array", "minItems": 1, "uniqueItems": true,
        "items": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"}
      },
      "events": {"$ref": "#/$defs/non_empty_unique_strings"},
      "environments": {
        "type": "array", "uniqueItems": true,
        "items": {"type": "string", "minLength": 1, "maxLength": 512}
      },
      "scopes": {
        "type": "array", "minItems": 1, "uniqueItems": true,
        "items": {"enum": ["actions.evaluate", "decisions.read", "permits.issue", "permits.consume", "reviews.read", "reviews.write", "metrics.read", "audit.read"]}
      },
      "runner_environments": {
        "type": "array", "minItems": 1, "uniqueItems": true,
        "items": {"enum": ["github-hosted", "self-hosted"]}
      }
    }
  },
  "$defs": {
    "non_empty_unique_strings": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 512}
    }
  }
}
