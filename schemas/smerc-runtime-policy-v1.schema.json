{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SMERC Runtime Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tenant_id", "policy_id", "policy_revision", "mode", "evidence_program_id", "evidence_ceiling", "fail_behavior", "approved_by_role", "effective_at", "thresholds"],
  "properties": {
    "version": {"const": "smerc.policy.v1"},
    "tenant_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "policy_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "policy_revision": {"type": "string", "minLength": 1, "maxLength": 64},
    "mode": {"enum": ["OBSERVE", "RECOMMEND", "ENFORCE"]},
    "evidence_program_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "evidence_ceiling": {"enum": ["STOP", "OBSERVE", "RECOMMEND", "LIMITED_ENFORCE", "CALIBRATED_ENFORCE"]},
    "fail_behavior": {"enum": ["report_unavailable", "fail_closed"]},
    "approved_by_role": {"type": "string", "minLength": 1, "maxLength": 128},
    "effective_at": {"type": "string", "format": "date-time"},
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deny_exposure_min", "deny_capacity_max", "deny_confidence_max", "deny_cancel_reliability_max", "deny_cancel_exposure_min", "escalate_stress_min", "freeze_confidence_max", "freeze_capacity_max", "throttle_authorization_min", "throttle_exposure_min"],
      "properties": {
        "deny_exposure_min": {"$ref": "#/$defs/score"},
        "deny_capacity_max": {"$ref": "#/$defs/score"},
        "deny_confidence_max": {"$ref": "#/$defs/score"},
        "deny_cancel_reliability_max": {"$ref": "#/$defs/score"},
        "deny_cancel_exposure_min": {"$ref": "#/$defs/score"},
        "escalate_stress_min": {"$ref": "#/$defs/score"},
        "freeze_confidence_max": {"$ref": "#/$defs/score"},
        "freeze_capacity_max": {"$ref": "#/$defs/score"},
        "throttle_authorization_min": {"$ref": "#/$defs/score"},
        "throttle_exposure_min": {"$ref": "#/$defs/score"}
      }
    }
  },
  "$defs": {"score": {"type": "number", "minimum": 0, "maximum": 1}}
}
