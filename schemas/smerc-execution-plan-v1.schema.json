{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smerc.example/schemas/smerc-execution-plan-v1.schema.json",
  "title": "SMERC Execution Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version", "execution_id", "audience", "working_directory", "command",
    "timeout_seconds", "cancel_grace_seconds", "environment_allowlist", "controls", "rollback"
  ],
  "properties": {
    "version": {"const": "smerc.execution-plan.v1"},
    "execution_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,191}$"},
    "audience": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "working_directory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!(?:.*[/\\\\])?\\.\\.(?:[/\\\\]|$)).+$"
    },
    "command": {"$ref": "#/$defs/argv"},
    "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "cancel_grace_seconds": {"type": "integer", "minimum": 1, "maximum": 60},
    "environment_allowlist": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z_][A-Z0-9_]{0,127}$"}
    },
    "controls": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "allOf": [
          {"pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
          {"not": {"const": "retain_cancel_handle"}}
        ]
      },
      "additionalProperties": {"$ref": "#/$defs/controlCommand"}
    },
    "rollback": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/rollback"}
      ]
    }
  },
  "$defs": {
    "argv": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "controlCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "timeout_seconds", "mechanism"],
      "properties": {
        "command": {"$ref": "#/$defs/argv"},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
        "mechanism": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "timeout_seconds", "mechanism", "on_failure", "on_timeout", "on_cancel"],
      "properties": {
        "command": {"$ref": "#/$defs/argv"},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 900},
        "mechanism": {"type": "string", "minLength": 1, "maxLength": 128},
        "on_failure": {"type": "boolean"},
        "on_timeout": {"type": "boolean"},
        "on_cancel": {"type": "boolean"}
      }
    }
  }
}
