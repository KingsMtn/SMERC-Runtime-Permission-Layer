{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smerc.example/schemas/smerc-authenticated-principal-v1.schema.json",
  "title": "SMERC Authenticated Principal v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["identity_version", "tenant_id", "principal_id", "scopes", "legacy"],
  "properties": {
    "identity_version": {"const": "smerc.principal.v1"},
    "tenant_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "principal_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "*",
          "actions.evaluate",
          "decisions.read",
          "permits.issue",
          "permits.consume",
          "reviews.read",
          "reviews.write",
          "metrics.read",
          "audit.read"
        ]
      }
    },
    "legacy": {"type": "boolean"}
  }
}
