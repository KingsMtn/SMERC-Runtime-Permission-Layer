{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smerc.example/schemas/smerc-access-token-v2.schema.json",
  "title": "SMERC Short-Lived Access Token v2 Claims",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version", "session_id", "issuer", "audience", "tenant_id",
    "principal_id", "scopes", "source_legacy", "issued_at",
    "not_before", "expires_at", "workload_context"
  ],
  "properties": {
    "version": {"const": "smerc.access-token.v2"},
    "session_id": {"type": "string", "pattern": "^session_[0-9a-f]{32}$"},
    "issuer": {"const": "smerc-pilot-api"},
    "audience": {"const": "smerc-runtime-api"},
    "tenant_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "principal_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "scopes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "actions.evaluate", "decisions.read", "permits.issue", "permits.consume",
          "reviews.read", "reviews.write", "metrics.read", "audit.read"
        ]
      }
    },
    "source_legacy": {"type": "boolean"},
    "issued_at": {"type": "integer", "minimum": 0},
    "not_before": {"type": "integer", "minimum": 0},
    "expires_at": {"type": "integer", "minimum": 1},
    "workload_context": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/workload_context"}
      ]
    }
  },
  "$defs": {
    "workload_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider", "subject", "repository", "repository_id", "repository_owner_id",
        "workflow_ref", "workflow_sha", "ref", "commit_sha", "run_id", "run_attempt",
        "actor_id", "event_name", "runner_environment", "token_id"
      ],
      "properties": {
        "provider": {"const": "github_actions_oidc"},
        "subject": {"type": "string", "minLength": 1, "maxLength": 512},
        "repository": {"type": "string", "minLength": 3, "maxLength": 512},
        "repository_id": {"type": "string", "pattern": "^[0-9]+$"},
        "repository_owner_id": {"type": "string", "pattern": "^[0-9]+$"},
        "workflow_ref": {"type": "string", "minLength": 1, "maxLength": 512},
        "workflow_sha": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
        "ref": {"type": "string", "minLength": 1, "maxLength": 512},
        "commit_sha": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
        "run_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "run_attempt": {"type": "string", "minLength": 1, "maxLength": 512},
        "actor_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "event_name": {"type": "string", "minLength": 1, "maxLength": 512},
        "runner_environment": {"enum": ["github-hosted", "self-hosted"]},
        "environment": {"type": "string", "minLength": 1, "maxLength": 512},
        "job_workflow_ref": {"type": "string", "minLength": 1, "maxLength": 512},
        "token_id": {"type": "string", "minLength": 1, "maxLength": 512}
      }
    }
  }
}
